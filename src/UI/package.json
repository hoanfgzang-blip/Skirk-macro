{
  "name": "ui",
  "version": "1.0.0",
  "description": "",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "package": "pnpm package:win",
    "package:win": "electron-builder --win --dir",
    "package:win:installer": "electron-builder --win nsis",
    "package:linux": "electron-builder --linux --dir --config.directories.output=../../build/app-linux",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "build": {
    "appId": "com.skirk.macro",
    "productName": "Cryss",
    "asar": true,
    "compression": "maximum",
    "directories": {
      "output": "../../build/app"
    },
    "win": {
      "electronLanguages": [
        "en-US",
        "vi"
      ],
      "requestedExecutionLevel": "requireAdministrator",
      "executableName": "Cryss",
      "icon": "icon.png",
      "extraResources": [
        {
          "from": "../../build/dist/Cryss.exe",
          "to": "Cryss.exe"
        }
      ]
    },
    "linux": {
      "target": "dir",
      "executableName": "Cryss",
      "icon": "icon.png",
      "extraResources": [
        {
          "from": "../../build/dist/Cryss",
          "to": "Cryss"
        }
      ]
    },
    "files": [
      "index.html",
      "main.js",
      "fe.js",
      "style.css",
      "icon.png"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3"
  }
}
